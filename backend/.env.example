PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/auditVault
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h
# Set your deployed frontend origin(s) in production. Comma-separate multiple values.
CLIENT_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTH_MAX_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
LOG_LEVEL=info
