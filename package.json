{
  "name": "auditvault",
  "version": "1.0.0",
  "private": true,
  "description": "AuditFlow local development runner",
  "scripts": {
    "install:all": "node scripts/install-all.js",
    "postinstall": "npm run install:all",
    "dev": "node scripts/dev.js dev",
    "start": "node scripts/dev.js start",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix auditflow-frontend run dev",
    "start:backend": "npm --prefix backend run start",
    "start:frontend": "npm --prefix auditflow-frontend run dev",
    "lint": "npm --prefix backend run lint && npm --prefix auditflow-frontend run lint",
    "test": "npm --prefix backend run test && npm --prefix auditflow-frontend run test",
    "build": "npm --prefix auditflow-frontend run build"
  },
  "license": "ISC",
  "type": "commonjs"
}
